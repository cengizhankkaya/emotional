			<key>CFBundleURLSchemes</key>
			<array>
				<string>emoti</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>Google Sign-In</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.739508543260-rvk20tdapl68r0ae5vkas3r438peqfuv</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>https</string>
		<string>http</string>
	</array>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Emoti uses your camera to stream live video to friends during video calls inside a shared watch room. For example, your friends can see you while you watch a movie together.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Emoti uses your microphone to transmit your voice to friends during audio and video calls inside a shared watch room. For example, you can talk with friends while watching a video together.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Emoti accesses your photo library so you can choose a video file from your device to play and share with friends in a watch room.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Emoti uses your local network to establish direct peer-to-peer connections with friends on the same Wi-Fi network. This enables low-latency video calls and synchronized playback without routing your audio and video through external servers.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Emoti does not use your location. This notice is required because an included library may reference location APIs for network or analytics services.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Emoti does not use your location in the background. This notice is required by third-party libraries.</string>
	<key>RTCApplicationGroupIdentifier</key>
	<string>group.com.esce.emoti</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
