{
    "rules": {
        "rooms": {
            "$roomId": {
                ".read": "auth != null",
                ".write": "auth != null && (!data.exists() || data.child('users').hasChild(auth.uid) || newData.child('users').hasChild(auth.uid))",
                "users": {
                    "$userId": {
                        ".write": "auth != null && auth.uid == $userId"
                    }
                },
                "signal": {
                    "$userId": {
                        ".read": "auth != null && auth.uid == $userId",
                        "$signalType": {
                            "$senderId": {
                                ".write": "auth != null && auth.uid == $senderId"
                            }
                        }
                    }
                },
                "usersState": {
                    "$userId": {
                        ".write": "auth != null && auth.uid == $userId"
                    }
                },
                "messages": {
                    ".read": "auth != null",
                    ".write": "auth != null"
                }
            }
        }
    }
}